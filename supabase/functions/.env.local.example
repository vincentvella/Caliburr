# Stripe test keys for local stripe-webhook development (make stripe-dev)
# Copy this file to .env.local and fill in your test values.
# STRIPE_WEBHOOK_SECRET is set automatically from `stripe listen --print-secret`.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_MONTHLY_PRICE_ID=price_test_...
STRIPE_ANNUAL_PRICE_ID=price_test_...
