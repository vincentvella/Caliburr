# Local config for make stripe-dev.
# Copy to .env.local and fill in your values.
# PROD_* values are temporarily swapped out during dev and restored on exit.

# Production values (restored on Ctrl+C)
PROD_STRIPE_WEBHOOK_SECRET=whsec_...
PROD_STRIPE_SECRET_KEY=sk_live_...
PROD_STRIPE_MONTHLY_PRICE_ID=price_live_...
PROD_STRIPE_ANNUAL_PRICE_ID=price_live_...

# Test values (active during make stripe-dev)
TEST_STRIPE_SECRET_KEY=sk_test_...
TEST_STRIPE_MONTHLY_PRICE_ID=price_test_...
TEST_STRIPE_ANNUAL_PRICE_ID=price_test_...
